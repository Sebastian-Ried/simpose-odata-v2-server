    "sequelize": "^6.x"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^24.10.1",
    "express": "^4.22.2",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
